# NexCode Environment Variables

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/nexcode

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email (Resend)
RESEND_API_KEY=

# Redis (Upstash)
REDIS_URL=
REDIS_TOKEN=

# Encryption
ENCRYPTION_KEY=
